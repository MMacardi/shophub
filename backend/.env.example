# ── ShopHub backend ── environment variables ──
# Copy this file to `.env` and fill in the values below.
# `.env` is loaded automatically by backend/config.py (python-dotenv).

# Flask
SECRET_KEY=shophub-dev-secret-key-change-in-prod
DATABASE_URL=sqlite:///shophub.db

# Aliyun DashScope — OpenAI-compatible chat API used by ShopBot
# Get a key from https://dashscope.console.aliyun.com/  (or the international console)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — defaults shown.
# Use dashscope.aliyuncs.com         if your key is from bailian.console.aliyun.com  (China region)
# Use dashscope-intl.aliyuncs.com    if your key is from modelstudio.console.alibabacloud.com (international)
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
